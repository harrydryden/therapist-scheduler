generator client {
  provider = "prisma-client-js"
  // Force Prisma Client regeneration after invalid_date_alert_at column removal
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User and Therapist Entities
// ============================================

// Represents a client/user who books appointments
// Each user has a unique 10-digit ID (odId) for easy reference
model User {
  id      String  @id @default(uuid())
  odId    String  @unique @map("od_id") // Unique 10-digit ID (e.g., "1234567890")
  email   String  @unique
  name    String?
  // Country code (ISO-like short code: UK, IE, US, CA, ES, DE, FR, PT, AU, NZ, ZA)
  // Used to determine timezone for agent communications. Database appointment
  // times remain in UK time; this controls how times are presented to the user.
  country String  @default("UK")

  // IANA timezone identifier (e.g. "Europe/London", "America/Los_Angeles").
  // Populated by the booking agent's `record_user_timezone` tool after the
  // agent asks where the user is based — necessary for users in multi-zone
  // countries (US, CA, AU, ...) so confirmation emails can quote times in
  // their actual local zone rather than falling back to UK time. Null for
  // users who haven't yet been asked or who are in single-zone countries
  // (the country default suffices there).
  timezone String? @map("timezone")

  // Mailing list opt-in. Mirrors the Notion `Subscribed` checkbox while the
  // Notion users database is still authoritative; reads switch to this column
  // in PR 2 of the Notion deprecation.
  subscribed Boolean @default(true)

  // Signup consent fields. Captured by the public /signup form. Legacy rows
  // (pre-signup-form) get consentGivenAt backfilled to createdAt — the
  // deployment owner has confirmed those users gave consent at the time.
  // Nullable on the booking flow (booking doesn't yet require these), so a
  // null value means the user has only ever booked, never signed up.
  priorTherapy            Boolean?  @map("prior_therapy")
  acknowledgedRealSession Boolean?  @map("acknowledged_real_session")
  agreedToFeedback        Boolean?  @map("agreed_to_feedback")
  consentGivenAt          DateTime? @map("consent_given_at")
  // 'signup_form' | 'booking' | 'admin' | 'legacy'. Helps distinguish data
  // provenance once the booking and signup paths both write here.
  signupSource            String?   @map("signup_source")

  // Agent profile (Layer C in the agent memory design). Cross-appointment
  // observations about this user that help the scheduling agent start
  // warm on subsequent bookings. Strictly scoped per User.id; see
  // agent-profile.service.ts for the read/write contract.
  agentNotes Json? @map("agent_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  appointments AppointmentRequest[]

  @@index([odId])
  @@index([email])
  @@index([subscribed])
  @@map("users")
}

// Represents a therapist who provides sessions
// Each therapist has a unique 10-digit ID (odId) for easy reference
model Therapist {
  id           String  @id @default(uuid())
  odId         String  @unique @map("od_id") // Unique 10-digit ID (e.g., "9876543210")
  // Public-facing identifier used by the frontend, booking endpoints, and the
  // ATS integration as the therapist's stable handle. Originally seeded with
  // the Notion page ID for therapists ingested while Notion was authoritative;
  // for new ingestions a uuid is generated. Nullable to permit therapists
  // whose Notion record has been deleted; rows without a notionId are matched
  // by their Postgres `id` instead.
  notionId     String? @unique @map("notion_id")
  email        String  @unique
  name         String
  // Country code (UK, IE, US, CA, ES, DE, FR, PT, AU, NZ, ZA). Drives timezone
  // for agent communication and the flag emoji on the public therapist card.
  country      String  @default("UK")

  // IANA timezone identifier (e.g. "Europe/London", "America/Los_Angeles").
  // The therapist's CANONICAL location — populated by either agent via
  // `record_therapist_timezone` after asking which city/region. Used for
  // resolving wall-clock times the therapist mentions, formatting emails
  // sent to them, and stamping new recurring schedules. Takes precedence
  // over `availability.timezone` because it's the therapist's *location*,
  // not a property of a specific schedule. Null until the agent has
  // confirmed; the resolver in therapist-timezone.service falls back
  // through availability.timezone → country default → platform default
  // exactly as before.
  timezone     String? @map("timezone")
  // Therapist's recurring availability. Source of truth — Notion is no longer
  // read or written for availability. Shape: { timezone: string, slots:
  // [{day, start, end}], exceptions?: [{date, available}] }. May be null until
  // the therapist provides availability (or the agent records what they share).
  availability Json?   @map("availability")

  // Episodic upcoming availability — one-off windows the therapist has shared
  // (typically captured by the availability-collection agent during onboarding
  // or as part of a nudge reply) that complement the recurring `availability`
  // schedule above. Shape: AvailabilityWindow[] from agent-memory.service.ts —
  // [{id, startsAt, endsAt, status, source, quote, recordedAt}] with ISO 8601
  // timestamps with offset. Past windows are filtered at read time and the
  // collection agent compacts the column on write so it doesn't grow forever.
  upcomingAvailability Json? @map("upcoming_availability")

  // Profile fields. Originally mirrored the Notion therapists database via a
  // one-shot Notion→Postgres backfill; Postgres is now the source of truth
  // and these columns are written directly by the ingestion pipeline.
  bio          String?  @db.Text
  // Multi-select category tags. Postgres String[] arrays so we can index/query
  // without JSON unwrapping. Empty array on rows that haven't been backfilled.
  approach     String[] @default([])
  style        String[] @default([])
  areasOfFocus String[] @default([]) @map("areas_of_focus")
  profileImage String?  @map("profile_image")
  bookingLink  String?  @map("booking_link")
  // Whether the therapist is accepting bookings at all. Default true so
  // legacy unbackfilled rows don't disappear from any Postgres-backed read.
  active       Boolean  @default(true)

  ingestedAt        DateTime? @map("ingested_at") // When the therapist was added to the platform
  lastNudgeAt       DateTime? @map("last_nudge_at") // When the last "still looking" nudge email was sent
  lastNudgeThreadId String?   @map("last_nudge_thread_id") // Gmail thread ID of the last nudge email (for reply detection)
  // How many "still looking for a client" nudges this therapist has been
  // sent. Bounds the otherwise-unbounded nudge loop: the nudge service
  // skips therapists who have reached THERAPIST_NUDGE.MAX_NUDGES and
  // escalates to an admin once instead of emailing them again. Previously
  // only lastNudgeAt was tracked, so a never-matched therapist was
  // re-nudged on the configured cadence forever.
  nudgeCount        Int       @default(0) @map("nudge_count")

  // Agent profile (Layer C in the agent memory design). Cross-appointment
  // observations about this therapist's scheduling style. Strictly
  // scoped per Therapist.id; see agent-profile.service.ts for the
  // read/write contract.
  agentNotes Json? @map("agent_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  appointments   AppointmentRequest[]
  conversations  TherapistConversation[]
  // Therapist-scoped tracked side effects (e.g. therapist-nudge
  // periodic emails). Appointment-scoped rows live under the
  // matching reverse-relation on AppointmentRequest. The CHECK
  // constraint on side_effect_logs guarantees exactly one parent.
  sideEffectLogs SideEffectLog[]

  @@index([odId])
  @@index([notionId])
  @@index([active])
  @@map("therapists")
}

// ============================================
// Appointment System
// ============================================

// Status values enforced at application level via APPOINTMENT_STATUS constants
// Using String (not enum) for compatibility with prisma db push on existing databases

model AppointmentRequest {
  id                    String  @id @default(uuid())
  userName              String? @map("user_name")
  userEmail             String  @map("user_email")
  therapistHandle       String  @map("therapist_handle")
  therapistEmail        String  @map("therapist_email")
  therapistName         String  @map("therapist_name")
  therapistAvailability Json?   @map("therapist_availability")
  status                String  @default("pending")

  // Bumped inside the atomic update of every status transition (see
  // appointment-lifecycle.service). Included in side-effect-tracker
  // idempotency keys so that re-entering the same status (e.g. cancel
  // → re-confirm) doesn't dedupe against the previous generation's
  // already-completed Slack/email side-effect rows.
  transitionGeneration Int @default(0) @map("transition_generation")

  // Links to User and Therapist entities (for data management)
  // NOTE: Optional for backwards compatibility with records created before User/Therapist
  // entities existed. All new appointments set these via getOrCreateUser/getOrCreateTherapist.
  // Orphaned records (null userId/therapistId) are logged during retention cleanup.
  userId            String?    @map("user_id")
  therapistId       String?    @map("therapist_id")
  user              User?      @relation(fields: [userId], references: [id])
  therapist         Therapist? @relation(fields: [therapistId], references: [id])
  conversationState Json?      @map("conversation_state")
  // FIX #21: Denormalized columns to avoid loading full conversationState blob (up to 500KB)
  // in list queries. Updated whenever conversationState is written.
  messageCount      Int        @default(0) @map("message_count")
  // Default to `initial_contact` so freshly-created rows (admin-create
  // flows, ATS hand-offs) carry a valid stage before the agent's first
  // tool run. Without this, list-view rows show null next-action until
  // the first inbound triggers `storeConversationState`. The agent
  // tool-loop's entry-side checkpoint bootstrap (`runToolLoop`) keeps
  // the JSONB blob's `checkpoint.stage` in sync with this column so
  // the next `storeConversationState` write doesn't null it.
  checkpointStage   String?    @default("initial_contact") @map("checkpoint_stage")
  // Denormalised `conversationState.checkpoint.checkpoint_at`. Populated
  // by the same two writers that maintain `checkpointStage`
  // (storeConversationState + applyCheckpointUpdate). Lets the chase
  // candidate query — which used to pull the full conversationState
  // JSON just to read one timestamp — read this column directly,
  // dropping the per-tick blob fetch entirely.
  checkpointAt      DateTime?  @map("checkpoint_at")
  // Agent-curated thread memory (Layer B in the agent memory design).
  // Free-form observations the agent retains via the `remember` tool —
  // preferences, constraints, prior decisions, situational context the
  // regex-based fact extractor doesn't catch. Strictly per-appointment;
  // see agent-memory.service.ts for the read/write contract.
  memory            Json?
  confirmedAt       DateTime?  @map("confirmed_at")
  confirmedDateTime String?    @map("confirmed_date_time") // The actual scheduled appointment date/time
  notes             String?
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  // Email thread tracking for deterministic matching
  // Separate threads for client and therapist conversations
  gmailThreadId          String? @map("gmail_thread_id") // Thread with the client
  initialMessageId       String? @map("initial_message_id")
  therapistGmailThreadId String? @map("therapist_gmail_thread_id") // Thread with the therapist

  // Voucher code used at booking time (what3words-style display code for analytics)
  voucherCode String? @map("voucher_code")

  // How the booking was initiated: 'agent_negotiated' (default) or 'direct_link'
  // direct_link means the user booked via the therapist's external booking page
  bookingMethod String @default("agent_negotiated") @map("booking_method")

  // Tracking code for deterministic email matching (embedded in subjects)
  // Format: SPL<number> (e.g., SPL1, SPL42) - UNIQUE per appointment
  // Each appointment gets its own tracking code for feedback forms and email matching
  // FIX #12: Add @unique constraint - tracking codes are semantically unique identifiers
  trackingCode String? @unique @map("tracking_code")

  // Idempotency key for preventing duplicate appointment creation
  // Generated client-side or computed from request data
  // Used to safely handle retries and double-clicks
  idempotencyKey String? @unique @map("idempotency_key")

  // Human takeover control fields
  humanControlEnabled Boolean   @default(false) @map("human_control_enabled")
  humanControlTakenBy String?   @map("human_control_taken_by")
  humanControlTakenAt DateTime? @map("human_control_taken_at")
  humanControlReason  String?   @map("human_control_reason")

  // 48-hour stale flagging
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  isStale        Boolean  @default(false) @map("is_stale")

  // Post-booking follow-up tracking
  meetingLinkCheckSentAt  DateTime? @map("meeting_link_check_sent_at")
  feedbackFormSentAt      DateTime? @map("feedback_form_sent_at")
  feedbackReminderSentAt  DateTime? @map("feedback_reminder_sent_at")
  confirmedDateTimeParsed DateTime? @map("confirmed_date_time_parsed")
  // Positive evidence that a real meeting link exists for this booking —
  // stamped when an inbound therapist email actually contains a meeting
  // URL (not merely a promise to send one). The lifecycle tick uses it to
  // tell a verified session_held transition from one it is asserting purely
  // because the clock passed: a confirmed booking where the therapist only
  // ever said "I'll send the invite" leaves this null, and that case is
  // logged + audited rather than silently treated as a held session.
  meetingLinkConfirmedAt  DateTime? @map("meeting_link_confirmed_at")

  // Rescheduling support
  reschedulingInProgress    Boolean @default(false) @map("rescheduling_in_progress")
  reschedulingInitiatedBy   String? @map("rescheduling_initiated_by")
  previousConfirmedDateTime String? @map("previous_confirmed_date_time")

  // Conversation stall detection (FIX NEW: detect spinning conversations)
  conversationStallAlertAt      DateTime? @map("conversation_stall_alert_at")
  conversationStallAcknowledged Boolean   @default(false) @map("conversation_stall_acknowledged")

  // Thread divergence tracking (FIX R3: alert when threads diverge critically)
  threadDivergedAt             DateTime? @map("thread_diverged_at")
  threadDivergenceDetails      String?   @map("thread_divergence_details")
  threadDivergenceAcknowledged Boolean   @default(false) @map("thread_divergence_acknowledged")

  // Last tool execution tracking (FIX T1: verify tool success)
  lastToolExecutedAt      DateTime? @map("last_tool_executed_at")
  lastToolExecutionFailed Boolean   @default(false) @map("last_tool_execution_failed")
  lastToolFailureReason   String?   @map("last_tool_failure_reason")

  // Session reminder tracking (Edge Case #6)
  reminderSentAt DateTime? @map("reminder_sent_at")

  // Auto-escalation tracking (Edge Case #7)
  autoEscalatedAt DateTime? @map("auto_escalated_at")

  // Chase follow-up tracking (Thread Lifecycle)
  // Agent sends one chase email to the non-responding party before recommending closure
  chaseSentAt      DateTime? @map("chase_sent_at") // When the chase email was sent
  chaseSentTo      String?   @map("chase_sent_to") // 'user' or 'therapist'
  chaseTargetEmail String?   @map("chase_target_email") // Email address chased

  // Closure recommendation tracking
  // After chase goes unanswered, system recommends admin close the thread
  closureRecommendedAt          DateTime? @map("closure_recommended_at")
  closureRecommendedReason      String?   @map("closure_recommended_reason")
  closureRecommendationActioned Boolean   @default(false) @map("closure_recommendation_actioned")

  // Relation to pending emails
  pendingEmails PendingEmail[]

  // Relation to the sibling conversation table (Phase 3a expand).
  // 1:1 — created lazily on first conversation write. During the
  // expand+dual-write phase, `conversationState` + `memory` are
  // mirrored to this table; reads still hit the columns on this
  // row. See docs/REFACTOR_PLAN.md for the cutover plan.
  conversation AppointmentConversation?

  // Relation to feedback submissions
  feedbackSubmissions FeedbackSubmission[]

  // Relation to audit events (referential integrity)
  auditEvents AppointmentAuditEvent[]

  // Relation to side effect logs (referential integrity)
  sideEffectLogs SideEffectLog[]

  // CONSTRAINT: Only one active appointment per user-therapist pair
  // This prevents duplicate bookings between the same user and therapist
  // Note: PostgreSQL partial unique index created via migration (see below)
  // Prisma doesn't support partial unique indexes natively, so this is enforced at app level
  // and backed by database trigger/constraint in migration

  // FIX #18: Consolidated indexes — removed standalone low-cardinality boolean indexes
  // (isStale, humanControlEnabled) which provide no selectivity benefit.
  // Kept compound indexes that are actually queried.
  // NOTE: @@index([status]) removed — redundant as a prefix of all compound indexes below
  //       (status,lastActivityAt), (status,isStale), (status,confirmedDateTimeParsed), etc.
  //       PostgreSQL uses the leftmost prefix of compound indexes for single-column queries.
  @@index([gmailThreadId])
  @@index([therapistGmailThreadId])
  @@index([userEmail])
  @@index([therapistHandle])
  @@index([userEmail, therapistHandle, status])
  @@index([status, lastActivityAt]) // For stale check queries
  @@index([status, isStale]) // For filtering active stale conversations
  @@index([confirmedAt]) // For dashboard stats queries
  @@index([therapistEmail]) // For email matching queries
  @@index([initialMessageId]) // For In-Reply-To/References header matching (Priority 2)
  @@index([status, confirmedDateTimeParsed]) // For follow-up queries with status filter
  @@index([conversationStallAlertAt]) // For admin alert dashboard
  @@index([lastToolExecutedAt]) // For stall detection queries
  @@index([status, reminderSentAt, confirmedDateTimeParsed]) // For reminder queries
  @@index([idempotencyKey, createdAt]) // For idempotency key lookups
  @@index([userId]) // For user lookup queries
  @@index([therapistId]) // For therapist lookup queries
  @@index([status, chaseSentAt]) // For chase follow-up queries
  @@index([closureRecommendedAt]) // For closure recommendation dashboard
  @@map("appointment_requests")
}

// Conversation state extracted from AppointmentRequest in Phase 3a
// of the refactor (see docs/REFACTOR_PLAN.md).
//
// Why split: `conversationState` is the largest field on the
// AppointmentRequest row (~500KB in the worst case, typically tens of
// KB for active conversations) and the booking-FSM column set is
// hot-read by background services that don't need the blob.
// `memory` is much smaller but shares the same "read-only by the
// agent / writer-by-the-tool" access pattern, so it lives here too.
//
// Lifecycle: created LAZILY by the first conversation write — both
// `storeConversationState` and `addNote` upsert into this table. The
// cascade delete via the FK keeps cleanup automatic when an
// appointment is removed.
//
// Migration phase (current PR — Phase 3a):
//   - Schema is EXPANDED: the new table exists, but the legacy
//     `conversationState` + `memory` columns on `appointment_requests`
//     are STILL the source of truth for reads.
//   - Every writer now DUAL-WRITES: same JSON to both tables, both
//     wrapped in the same transaction.
//   - A backfill script copies pre-existing rows.
//
// Follow-up PR (Phase 3b — cutover):
//   - Reads switch to this table.
//   - Dual-write continues for safety so a rollback is one-line.
//
// Follow-up PR (Phase 3c — contract):
//   - Once cutover is proven in production for >= 1 week:
//     legacy columns dropped from `appointment_requests`.
model AppointmentConversation {
  // Primary key IS the appointment id — 1:1 enforced at the schema
  // level. No surrogate row id, so the join is a trivial PK lookup
  // and there's no chance of orphaned rows.
  appointmentId String @id @map("appointment_id")

  // Full conversation log (system prompt + messages + checkpoint +
  // facts). Up to ~500KB in the largest cases.
  conversationState Json? @map("conversation_state")

  // Agent-curated Layer B thread memory (notes + availability windows).
  // Distinct from conversationState because the agent writes it via a
  // separate tool (`remember`) and the eviction model is different
  // (FIFO with content-hash dedup; see agent-memory.service.ts).
  memory Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Cascade delete keeps cleanup automatic. The FK is also the PK,
  // so the relation is unambiguous and 1:1 at the schema level.
  appointment AppointmentRequest @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_conversations")
}

// Therapist-only conversations handled by the availability-collection agent.
//
// Distinct from AppointmentRequest, which is always anchored to a specific
// user↔therapist booking and runs the full booking lifecycle. A
// TherapistConversation has no user counterpart — it exists to collect
// availability from the therapist (and only the therapist) so that when a
// booking is later needed, the booking agent has fresh data to negotiate
// against. The availability agent NEVER proposes specific times, confirms
// bookings, or creates AppointmentRequest rows — those are strictly the
// booking agent's responsibilities.
//
// Two creation paths:
//   - `kind = 'onboarding'`: outbound first-contact email sent after the
//     therapist is added to the platform via PDF ingestion. The therapist
//     is being recruited; the immediate downstream use of their
//     availability is a single trial session, but the booking of that
//     session happens through the standard booking agent (with a Spill
//     team member as the user), not here.
//   - `kind = 'nudge_reply'`: the existing "still looking" nudge email
//     now includes an availability ask, and replies route here instead
//     of landing in the unmatched-email queue.
//
// Supersession: if a client booking request lands for this therapist while
// a conversation here is active, the booking agent takes over the
// relationship. We mark `superseded_at` + `superseded_by_appointment_id`,
// and the email dispatcher captures any future reply on this thread
// silently — except for the very first one, which gets a one-shot ack
// (`superseded_ack_sent`) explaining we've moved the conversation.
model TherapistConversation {
  id          String    @id @default(uuid())
  therapistId String    @map("therapist_id")
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  // 'onboarding' | 'nudge_reply'. Drives which prompt + tools the
  // availability agent loads. Immutable after creation.
  kind   String
  // 'active' | 'completed' | 'superseded' | 'abandoned'. Lifecycle is
  // intentionally simpler than AppointmentRequest's because there's no
  // bilateral booking flow to coordinate — the agent collects info and
  // marks complete (or supersedes/abandons).
  status String @default("active")

  // Gmail thread tracking. Mirrors AppointmentRequest.therapistGmailThreadId
  // semantics — the deterministic match key the inbound thread-matcher
  // uses to route the therapist's replies back to this conversation.
  gmailThreadId    String? @map("gmail_thread_id")
  initialMessageId String? @map("initial_message_id")

  // Agent state. Same shape contract as AppointmentRequest.conversationState
  // / .memory so the availability agent can reuse the agent-tool-loop +
  // agent-memory plumbing without divergent type guards.
  conversationState Json? @map("conversation_state")
  memory            Json?
  messageCount      Int   @default(0) @map("message_count")

  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  isStale        Boolean  @default(false) @map("is_stale")

  // Human takeover — same fields as AppointmentRequest so the admin UI
  // can render therapist conversations alongside appointment threads.
  humanControlEnabled Boolean   @default(false) @map("human_control_enabled")
  humanControlTakenBy String?   @map("human_control_taken_by")
  humanControlTakenAt DateTime? @map("human_control_taken_at")
  humanControlReason  String?   @map("human_control_reason")

  // Supersession. Set atomically when a booking request comes in for this
  // therapist while this conversation is active. `superseded_ack_sent`
  // guards the one-shot "we've moved this conversation" reply so we
  // don't ack repeatedly if the therapist keeps replying.
  supersededAt              DateTime? @map("superseded_at")
  supersededByAppointmentId String?   @map("superseded_by_appointment_id")
  supersededAckSent         Boolean   @default(false) @map("superseded_ack_sent")

  // Atomic-lock anchor for the tool executor's human-control gate. The
  // executor does an `updateMany` with `humanControlEnabled: false +
  // status: 'active'` as predicate and this timestamp as the data field;
  // if 0 rows match, the tool call is skipped. Same pattern as the
  // booking executor uses on AppointmentRequest.lastToolExecutedAt.
  lastToolExecutedAt DateTime? @map("last_tool_executed_at")

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([therapistId])
  @@index([gmailThreadId]) // Inbound thread-matcher lookup
  @@index([status])
  @@index([kind, status]) // For admin listings filtered by both
  @@index([status, lastActivityAt]) // Stale-check scans
  @@map("therapist_conversations")
}

model PendingEmail {
  id            String    @id @default(uuid())
  toEmail       String    @map("to_email")
  subject       String
  body          String    @db.Text // Allow long email bodies
  status        String    @default("pending") // pending, sent, failed, abandoned
  appointmentId String?   @map("appointment_id")
  errorMessage  String?   @map("error_message")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  retryCount    Int       @default(0) @map("retry_count")
  lastRetryAt   DateTime? @map("last_retry_at")
  nextRetryAt   DateTime? @map("next_retry_at")

  // Foreign key relation to AppointmentRequest
  // Cascade delete ensures PendingEmails are cleaned up when their appointment is deleted
  appointment AppointmentRequest? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([appointmentId])
  @@index([status, createdAt]) // For ordered pending email queries
  @@index([status, nextRetryAt]) // For retry scheduling
  @@map("pending_emails")
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  title     String? // Optional title for organization
  content   String   @db.Text
  audience  String // 'therapist' | 'user' | 'both'
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("knowledge_base")
}

// Track therapist booking availability status
model TherapistBookingStatus {
  id                  String    @id // therapistHandle (legacy notionId or therapist.id)
  therapistName       String    @map("therapist_name")
  hasConfirmedBooking Boolean   @default(false) @map("has_confirmed_booking")
  confirmedAt         DateTime? @map("confirmed_at")
  frozenAt            DateTime? @map("frozen_at") // When frozen due to first request
  frozenUntil         DateTime? @map("frozen_until") // Legacy field, kept for compatibility
  uniqueRequestCount  Int       @default(0) @map("unique_request_count")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Admin alert for prolonged inactivity (72h with 2 threads)
  adminAlertAt           DateTime? @map("admin_alert_at")
  adminAlertAcknowledged Boolean   @default(false) @map("admin_alert_acknowledged")

  @@index([hasConfirmedBooking])
  // frozenUntil index removed — legacy field no longer queried, was pure write overhead
  @@index([adminAlertAt])
  @@map("therapist_booking_status")
}

// Track processed Gmail messages for deduplication.
//
// The `context` column records WHY the message was marked processed.
// Without this, debugging "why is this message marked processed?" required
// grepping logs for the Gmail message ID. Common values:
//   'successfully-processed'         — agent processed it normally
//   'unparseable'                    — MIME parse failed
//   'bounce'                         — bounce notification, handled
//   'own-email'                      — our own outgoing email
//   'weekly-mailing-reply'           — routed to weekly mailing handler
//   'unmatched-abandoned'            — couldn't match to an appointment
//   'divergence-blocked-abandoned'   — thread divergence retry budget exhausted
//   'processing-failed-abandoned'    — agent errored out 3 times
//   'legacy'                         — pre-existing row from before the column was added
model ProcessedGmailMessage {
  id          String   @id // Gmail message ID
  processedAt DateTime @default(now()) @map("processed_at")
  context     String   @default("legacy") // See model doc for values

  @@index([processedAt])
  @@index([context])
  @@map("processed_gmail_messages")
}

// Track unmatched email retry attempts (for E3 fix)
// Used as database fallback when Redis is unavailable
model UnmatchedEmailAttempt {
  id          String   @id // Gmail message ID
  attempts    Int      @default(1)
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  abandoned   Boolean  @default(false)

  @@index([abandoned])
  @@index([lastSeenAt])
  @@map("unmatched_email_attempts")
}

// Track per-message processing failures (post-match, e.g. agent throws).
// Database is authoritative — Redis is used as a cache only. This prevents
// the missed-message scanner from looping forever if Redis is unavailable
// (the previous Redis-only counter returned 1 every time on failure, so
// abandonment never triggered).
//
// Also stores the last error text so the admin scan-preview UI can show
// WHY each MISSED message is stuck without diving into logs.
model MessageProcessingFailure {
  id            String   @id // Gmail message ID
  attempts      Int      @default(1)
  lastError     String   @map("last_error") @db.Text
  firstFailedAt DateTime @default(now()) @map("first_failed_at")
  lastFailedAt  DateTime @default(now()) @map("last_failed_at")
  abandoned     Boolean  @default(false) // True after exceeding MAX_PROCESSING_FAILURES

  @@index([abandoned])
  @@index([lastFailedAt])
  @@index([abandoned, lastFailedAt]) // For admin "retry recent abandonments" queries
  @@map("message_processing_failures")
}

// Runtime-configurable system settings
// Each setting is stored as a key-value pair with metadata
model SystemSetting {
  id           String   @id // Setting key (e.g., "stale.markStaleHours")
  value        String // JSON-encoded value
  category     String // Category for grouping (e.g., "stale", "postBooking", "agent")
  label        String // Human-readable label
  description  String? // Optional description for the admin UI
  valueType    String // Type hint: "number", "boolean", "string", "json"
  minValue     Float?   @map("min_value") // For numeric values
  maxValue     Float?   @map("max_value") // For numeric values
  defaultValue String   @map("default_value") // Default value (JSON-encoded)
  updatedAt    DateTime @updatedAt @map("updated_at")
  updatedBy    String?  @map("updated_by") // Admin who last updated

  @@index([category])
  @@map("system_settings")
}

// Append-only audit log for appointment events
// Inspired by OpenClaw's JSONL transcript pattern - never modified, only appended
// Provides full auditability and debuggability for scheduling conversations
model AppointmentAuditEvent {
  id                   String   @id @default(uuid())
  appointmentRequestId String   @map("appointment_request_id")
  eventType            String   @map("event_type") // email_received, email_sent, tool_executed, claude_response, status_change, human_control, error
  actor                String // agent, admin, user, therapist, system
  payload              Json? // Event-specific data
  createdAt            DateTime @default(now()) @map("created_at")

  // Foreign key relation to ensure referential integrity
  // Cascade delete: audit events are deleted when appointment is deleted
  appointment AppointmentRequest @relation(fields: [appointmentRequestId], references: [id], onDelete: Cascade)

  @@index([appointmentRequestId])
  @@index([eventType])
  @@index([createdAt])
  @@index([appointmentRequestId, createdAt]) // For replaying events in order
  @@map("appointment_audit_events")
}

// Track weekly mailing inquiry conversations
// When users reply to weekly promotional emails with questions,
// the agent handles these as lightweight inquiries (not full bookings)
model WeeklyMailingInquiry {
  id                  String   @id @default(uuid())
  userEmail           String   @map("user_email")
  userName            String?  @map("user_name")
  gmailThreadId       String?  @map("gmail_thread_id")
  conversationState   Json?    @map("conversation_state")
  status              String   @default("active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  humanControlEnabled Boolean  @default(false) @map("human_control_enabled")

  @@index([userEmail])
  @@index([gmailThreadId])
  @@index([status])
  @@map("weekly_mailing_inquiries")
}

// ============================================
// Feedback Form System
// ============================================

// Stores form configuration (admin-editable questions and settings)
model FeedbackFormConfig {
  id          String  @id @default("default") // Single config for now, could support multiple forms later
  formName    String  @default("Therapy Interview Feedback") @map("form_name")
  description String? @db.Text

  // Welcome/intro screen
  welcomeTitle   String @default("Session Feedback") @map("welcome_title")
  welcomeMessage String @default("Please take a moment to share your feedback about your therapy session.") @map("welcome_message") @db.Text

  // Thank you screen
  thankYouTitle   String @default("Thank you!") @map("thank_you_title")
  thankYouMessage String @default("Thanks for sharing your feedback - we really appreciate it.") @map("thank_you_message") @db.Text

  // Form questions (JSON array of question configs)
  // Each question: { id, type, question, required, options?, scaleLabels? }
  questions        Json @default("[]")
  questionsVersion Int  @default(0) @map("questions_version")

  // Settings
  isActive              Boolean @default(true) @map("is_active")
  requiresAuth          Boolean @default(false) @map("requires_auth") // If true, requires valid SPL code
  requireExplanationFor Json    @default("[\"No\", \"Unsure\"]") @map("require_explanation_for") // Which choice answers require explanation text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feedback_form_config")
}

// Stores individual feedback submissions
model FeedbackSubmission {
  id String @id @default(uuid())

  // Link to appointment via SPL code
  trackingCode         String? @map("tracking_code") // SPL code from URL
  appointmentRequestId String? @map("appointment_request_id")

  // User info (from appointment lookup or manual entry)
  userEmail     String? @map("user_email")
  userName      String? @map("user_name")
  therapistName String  @map("therapist_name")

  // Form responses (JSON object with question id -> response value)
  // All answers stored here - no hardcoded columns, so form questions can change freely
  responses Json

  // Tracks which form version was used, so we can interpret responses correctly
  formVersion Int @default(0) @map("form_version")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  appointment AppointmentRequest? @relation(fields: [appointmentRequestId], references: [id], onDelete: SetNull)

  @@index([trackingCode])
  @@index([appointmentRequestId])
  @@index([userEmail])
  @@index([therapistName])
  @@index([createdAt])
  @@map("feedback_submissions")
}

// ============================================
// Side Effect Tracking (Two-Phase Commit Pattern)
// ============================================

// Tracks completion status of side effects triggered by status transitions
// Used to ensure all side effects complete and can be retried if needed
model SideEffectLog {
  id String @id @default(uuid())

  // Scope: EXACTLY ONE of appointmentId / therapistId is non-null.
  // Enforced at the DB layer by side_effect_logs_scope_check.
  // Appointment-scoped is the common case (status-transition emails,
  // periodic chases for a specific booking). Therapist-scoped covers
  // cadence comms that aren't tied to an appointment, e.g. the weekly
  // therapist-nudge.
  appointmentId String? @map("appointment_id")
  therapistId   String? @map("therapist_id")

  // Type of side effect
  effectType String @map("effect_type") // 'slack_notify', 'email_client', 'email_therapist', 'user_sync', 'therapist_freeze_sync'

  // Triggering transition
  transition String // e.g., 'confirmed', 'cancelled', 'completed'

  // Status tracking
  status   String  @default("pending") // pending, completed, failed, abandoned
  attempts Int     @default(0)
  errorLog String? @map("error_log") @db.Text

  // Rendered payload captured at registration time so retries can replay the
  // exact original outbound (e.g. localised email subject/body, slack args).
  // Optional — some effects (e.g. slack notify) don't need a payload because
  // their retry path re-fetches state from the DB.
  payload Json? @map("payload")

  // Timing
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  lastAttempt DateTime? @map("last_attempt_at")

  // Idempotency - prevent duplicate execution
  idempotencyKey String @unique @map("idempotency_key")

  // Foreign key relations — at most one will be non-null per row (see
  // CHECK constraint above). Cascade delete: side effect logs are
  // deleted when the parent appointment or therapist is deleted.
  appointment AppointmentRequest? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  therapist   Therapist?          @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([therapistId])
  @@index([status])
  @@index([effectType, status])
  @@index([status, lastAttempt]) // For retry queries
  @@map("side_effect_logs")
}

// ============================================
// Work Reports (Daily Agent Activity Summary)
// ============================================

// Stores daily work reports generated at 9am UK time on weekdays (Mon-Fri).
// Each report summarises agent activity since the previous report.
// Monday reports cover Fri 9am → Mon 9am (including the weekend).
model WorkReport {
  id String @id @default(uuid())

  // Time window covered by this report
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  // Email metrics
  emailsSent     Int @default(0) @map("emails_sent")
  emailsReceived Int @default(0) @map("emails_received")

  // Appointment lifecycle metrics
  appointmentsCreated   Int @default(0) @map("appointments_created")
  appointmentsConfirmed Int @default(0) @map("appointments_confirmed")
  appointmentsCompleted Int @default(0) @map("appointments_completed")
  appointmentsCancelled Int @default(0) @map("appointments_cancelled")

  // Alert & escalation metrics
  staleConversationsFlagged Int @default(0) @map("stale_conversations_flagged")
  humanControlTakeovers     Int @default(0) @map("human_control_takeovers")
  chaseFollowUpsSent        Int @default(0) @map("chase_follow_ups_sent")
  closureRecommendations    Int @default(0) @map("closure_recommendations")

  // Current pipeline snapshot at report time
  pipelinePending     Int @default(0) @map("pipeline_pending")
  pipelineContacted   Int @default(0) @map("pipeline_contacted")
  pipelineNegotiating Int @default(0) @map("pipeline_negotiating")
  pipelineConfirmed   Int @default(0) @map("pipeline_confirmed")

  // Feedback received in period
  feedbackSubmissions Int @default(0) @map("feedback_submissions")

  // AI-generated synopsis of work done in the period
  synopsis String? @db.Text

  // Slack delivery tracking
  slackSentAt DateTime? @map("slack_sent_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([periodEnd])
  @@index([createdAt])
  @@map("work_reports")
}

// ============================================
// Voucher Tracking (Use-It-or-Lose-It Lifecycle)
// ============================================

// Tracks per-user voucher lifecycle state for the weekly mailing voucher system.
// Each user (keyed by email) has at most one active voucher at a time.
// Strike counting drives auto-unsubscribe after consecutive expired vouchers.
model VoucherTracking {
  id                String    @id // User email (lowercase)
  strikeCount       Int       @default(0) @map("strike_count") // Consecutive expired vouchers
  lastVoucherSentAt DateTime? @map("last_voucher_sent_at") // When current voucher was issued
  lastVoucherToken  String?   @map("last_voucher_token") @db.Text // Full HMAC token (reused in reminder emails)
  lastVoucherUsedAt DateTime? @map("last_voucher_used_at") // When user last booked with a voucher
  reminderSentAt    DateTime? @map("reminder_sent_at") // When mid-cycle reminder was sent
  unsubscribedAt    DateTime? @map("unsubscribed_at") // When auto-unsubscribed (audit)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([strikeCount])
  @@index([lastVoucherSentAt])
  @@index([unsubscribedAt])
  @@map("voucher_tracking")
}

// ============================================
// Signup Invitations
// ============================================

// Admin-issued one-time signup invitations. The token sent to the prospect
// is a 32-byte random opaque string; only its SHA-256 hash is stored here.
// Lifecycle: pending → accepted (signup completed using the token) | revoked
// (admin) | passively expired (expiresAt < now). Rows are kept indefinitely
// for audit; "delete" is not a state.
model SignupInvitation {
  id             String    @id @default(uuid())
  // Lowercased email of the invitee. NOT @unique — once a row is accepted or
  // revoked, the same email can be re-invited (the service auto-revokes any
  // pending invitation for that email before creating a new one).
  email          String
  // Optional name the admin wants to pre-fill on the signup form.
  name           String?
  // SHA-256 hex digest of the raw token. The raw token is only ever in the
  // emailed URL; if the DB leaks, leaked rows can't be redeemed.
  tokenHash      String    @unique @map("token_hash")
  // Who issued it (admin secret can't carry an identity, so this is the
  // human-readable label the admin enters or 'admin' fallback).
  invitedBy      String    @map("invited_by")
  expiresAt      DateTime  @map("expires_at")
  acceptedAt     DateTime? @map("accepted_at")
  // Postgres User row created from this invite, linked at acceptance time
  // for conversion reporting. Optional — older rows pre-link were not
  // preserved.
  acceptedUserId String?   @map("accepted_user_id")
  revokedAt      DateTime? @map("revoked_at")
  // Last time the admin re-sent the email (counter is implicit: how many
  // sends happened since createdAt; admin-only, not displayed publicly).
  lastSentAt     DateTime  @default(now()) @map("last_sent_at")
  sendCount      Int       @default(1) @map("send_count")
  // When the pre-expiry reminder was sent. Null means "no reminder sent yet";
  // the background tick uses this to make sure each invite gets at most one
  // reminder regardless of how many cycles it sees.
  reminderSentAt DateTime? @map("reminder_sent_at")
  // When this row was archived (deleted-but-soft) by the cleanup job. Set
  // for old expired/revoked rows so they fall out of the default admin
  // listing without losing the audit trail.
  archivedAt     DateTime? @map("archived_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([acceptedAt])
  @@index([revokedAt])
  @@index([expiresAt])
  @@index([archivedAt])
  @@map("signup_invitations")
}
